# OpenAI API Key (LLM 답변 생성용, 인덱스 빌드 시 파일별 요약에도 사용)
OPENAI_API_KEY=sk-...

# 인덱스 빌드 요약 (선택): false면 요약 청크 생략. 모델 기본 gpt-4o-mini (config.py)
# INDEX_SUMMARY_ENABLED=true
# INDEX_SUMMARY_MODEL=gpt-4o-mini
# INDEX_SUMMARY_MAX_INPUT_CHARS=14000

# ----- 구글 드라이브 (선택) -----
# build_index.py 기본은 로컬 data/portfolio 만 사용합니다.
# 드라이브에서 빌드하려면: GOOGLE_DRIVE_FOLDER_ID 설정 + INDEX_BUILD_USE_LOCAL_ONLY=false
# 설정 시 build_index.py 가 로컬 data/portfolio 대신 구글 드라이브 폴더에서 문서를 로드합니다.
# 폴더 ID: drive.google.com/drive/folders/ 여기서 /folders/ 뒤 문자열
# GOOGLE_DRIVE_FOLDER_ID=1abc...
# OAuth 인증 파일 경로 (미설정 시 ~/.credentials/ 사용)
# GOOGLE_DRIVE_CREDENTIALS_PATH=
# GOOGLE_DRIVE_TOKEN_PATH=
# 하위 폴더까지 포함할지 (true/false)
# GOOGLE_DRIVE_RECURSIVE=false

# ----- LangSmith (선택) -----
# 설정 시 RAG/라우터 등 LangChain 실행이 LangSmith에 트레이스로 기록됩니다.
# https://smith.langchain.com/ 에서 API 키 발급 후 아래 설정.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=scy-rag

# ----- 디버깅 (선택) -----
# 앱 무한 로딩 등 디버깅 시: 1 로 설정 후 터미널에서 앱 실행하면 [RAG], [APP] 로그가 출력됨
# DEBUG_RAG=1
